# Copy this file to server/.env and fill in your values.

# ─── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vien_shoes

# ─── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Server ────────────────────────────────────────────────────────
PORT=4000

# Required to access admin endpoints (e.g. GET /api/contact).
# Generate any random string. Send it as x-admin-token header.
ADMIN_TOKEN=change-me

# ─── Optional: client overrides (place in client/.env) ─────────────
# In dev the client uses Vite's proxy and hits /api directly.
# Set VITE_API_BASE only if you deploy the client separately from the API.
# VITE_API_BASE=https://api.example.com
