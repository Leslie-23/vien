{
  "name": "shoesco",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install": "npm install",
    "dev": "npx concurrently \"npm --workspace client run dev\" \"npm --workspace server run dev\"",
    "client": "npm --workspace client run dev",
    "server": "npm --workspace server run dev",
    "build": "npm --workspace client run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
